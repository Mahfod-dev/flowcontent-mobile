{
  "expo": {
    "name": "FlowContent",
    "slug": "flowcontent-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flowcontent",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flowcontent.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "FlowContent utilise le micro pour la saisie vocale.",
        "NSSpeechRecognitionUsageDescription": "FlowContent utilise la reconnaissance vocale pour transcrire vos messages.",
        "NSPhotoLibraryUsageDescription": "FlowContent accède à vos photos pour les joindre aux messages.",
        "NSPhotoLibraryAddUsageDescription": "FlowContent enregistre des images générées dans votre galerie.",
        "NSFaceIDUsageDescription": "FlowContent utilise Face ID pour protéger l'accès à votre compte.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.124777433323-ckpmkadp96nvc78q4vh3grr08fte0hfr"
            ]
          }
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyTracking": false
      },
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "package": "com.flowcontent.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
