# FlowContent Mobile - Environment Variables
# Copy to .env and fill in values

# Backend API
EXPO_PUBLIC_API_URL=https://flowbackendapi.store

# EAS / push notifications — must match `extra.eas.projectId` in app.json.
# Used by notifications.ts (falls back to a hard-coded value).
EXPO_PUBLIC_EAS_PROJECT_ID=5b21a603-9782-43d0-ab6d-dfeee96622ba

# Google OAuth (create in Google Cloud Console > Credentials)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=323350263219-n1arqbtr8cndcqt6mn1qb4ee9q67i39g.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Supabase (optional — currently unused)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
