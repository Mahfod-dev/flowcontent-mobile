{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://flowbackendapi.store"
      }
    },
    "preview": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "image": "sdk-55"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://flowbackendapi.store",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "simulator": {
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://flowbackendapi.store"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://flowbackendapi.store"
      }
    }
  },
  "submit": {
    "preview": {},
    "production": {}
  }
}
